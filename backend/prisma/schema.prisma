  jobName   String   @map("job_name")
  runDate   DateTime @map("run_date") @db.Date
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([jobName, runDate])
  @@map("cron_run_locks")
}

// ─────────────────────────────────────────────
