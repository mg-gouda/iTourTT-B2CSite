// ─────────────────────────────────────────────

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  userName  String   @map("user_name")
  action    String // CREATE, UPDATE, DELETE
  entity    String // e.g. "TrafficJob", "Agent", "Invoice"
