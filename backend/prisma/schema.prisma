  trafficJobId String   @unique @map("traffic_job_id")
  repId        String   @map("rep_id")
  attendance   Boolean  @default(false) // 20 pts — In Place evidence
  appearance   Boolean  @default(false) // 15 pts — In Place evidence
  work         Boolean  @default(false) // 15 pts — Completed status
  survey       Boolean  @default(false) // 15 pts — Guest survey submitted
  review       Boolean  @default(false) // 35 pts — manual
  scoredById   String   @map("scored_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  trafficJob TrafficJob @relation(fields: [trafficJobId], references: [id])
  rep        Rep        @relation(fields: [repId], references: [id])
  scoredBy   User       @relation("RepScoreScoredBy", fields: [scoredById], references: [id])

  @@map("rep_job_scores")
}

// ─────────────────────────────────────────────
// ARRIVAL GUEST SURVEY (native, filled by rep per ARR job)
// ─────────────────────────────────────────────

model GuestSurvey {
  id            String @id @default(uuid())
  trafficJobId  String @unique @map("traffic_job_id")
  repId         String @map("rep_id")
  submittedById String @map("submitted_by_id")

  ageRange         String  @map("age_range") // "20-30" | "30-45" | "45-60"
  noOfAdults       Int     @map("no_of_adults")
  flightNo         String  @map("flight_no")
  noOfInfants      Int     @default(0) @map("no_of_infants")
  stayLength       String? @map("stay_length")
  jobReference     String  @map("job_reference")
  repeaterGuest    String  @map("repeater_guest") // "YES" | "NO"
  guestNationality String  @map("guest_nationality")
  noOfChildren     Int     @default(0) @map("no_of_children")
  localTravelAgent String? @map("local_travel_agent")
  hotelName        String  @map("hotel_name")
  email            String?
  generalComment   String  @map("general_comment")
  contactNumber    String  @map("contact_number") // WhatsApp / Viber / Telegram

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  trafficJob TrafficJob @relation(fields: [trafficJobId], references: [id])
  rep        Rep        @relation(fields: [repId], references: [id])

  @@index([repId])
  @@index([createdAt])
  @@map("guest_surveys")
}

model DriverJobScore {
  id             String   @id @default(uuid())
  trafficJobId   String   @unique @map("traffic_job_id")
  driverId       String   @map("driver_id")
  attendance     Boolean  @default(false) // 30 pts — manual
  appearance     Boolean  @default(false) // 20 pts — manual
  carCleanliness Boolean  @default(false) @map("car_cleanliness") // 10 pts — manual
  maintenance    Boolean  @default(false) // 10 pts — manual
  work           Boolean  @default(false) // 20 pts — auto from COMPLETED status
  scoredById     String   @map("scored_by_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  trafficJob TrafficJob @relation(fields: [trafficJobId], references: [id])
  driver     Driver     @relation(fields: [driverId], references: [id])
  scoredBy   User       @relation("DriverScoreScoredBy", fields: [scoredById], references: [id])

  @@map("driver_job_scores")
}

// ─────────────────────────────────────────────
// DEVICE TOKENS (FCM push notifications)
// ─────────────────────────────────────────────

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String
  platform  String // 'ios' | 'android'
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@index([userId])
  @@map("device_tokens")
}

// ─────────────────────────────────────────────
// WEBSITE SETTINGS (B2C CMS - singleton)
// ─────────────────────────────────────────────

model WebsiteSettings {
  id String @id @default(uuid())

  // ── Site Identity ──
  siteName       String  @default("iTour Transfers") @map("site_name")
  siteLogoUrl    String? @map("site_logo_url")
  siteFaviconUrl String? @map("site_favicon_url")

  // ── Typography ──
  fontFamily String @default("Inter") @map("font_family")

  // ── Color Theme ──
  primaryColor     String @default("#3b82f6") @map("primary_color")
  accentColor      String @default("#8b5cf6") @map("accent_color")
  heroGradientFrom String @default("#1a1a2e") @map("hero_gradient_from")
  heroGradientTo   String @default("#0f3460") @map("hero_gradient_to")
  navBgColor       String @default("#1a1a2e") @map("nav_bg_color")
  footerBgColor    String @default("#1a1a2e") @map("footer_bg_color")

  // ── Header/Footer Presets ──
  headerPreset String @default("default") @map("header_preset")
  footerPreset String @default("default") @map("footer_preset")

  // ── Hero Section Content ──
  heroTitle    String  @default("Book Your Airport Transfer") @map("hero_title")
  heroSubtitle String  @default("Safe, comfortable, and reliable private transfers across Egypt.") @map("hero_subtitle")
  heroCta1Text String  @default("Book Now") @map("hero_cta1_text")
  heroCta2Text String  @default("Track a Booking") @map("hero_cta2_text")
  heroImageUrl String? @map("hero_image_url")

  // ── Features Section ──
  featuresEnabled Boolean @default(true) @map("features_enabled")
  featuresTitle   String  @default("Why Choose Us?") @map("features_title")
  featuresJson    Json?   @map("features_json")

  // ── Contact Info ──
  contactEmail    String? @map("contact_email")
  contactPhone    String? @map("contact_phone")
  contactWhatsapp String? @map("contact_whatsapp")
  socialFacebook  String? @map("social_facebook")
  socialInstagram String? @map("social_instagram")
  socialTwitter   String? @map("social_twitter")

  // ── Internal Booking Notifications ──
  // Comma-separated recipients for operations alerts on new / amended / cancelled
  // B2C bookings, and for finance alerts when a B2C booking is paid. Internal
  // only — never returned by the public website-settings endpoint.
  opsNotificationEmails     String? @map("ops_notification_emails")
  financeNotificationEmails String? @map("finance_notification_emails")

  // ── Bank Payment ──
  bankPaymentEnabled Boolean @default(false) @map("bank_payment_enabled")
  bankPaymentMessage String  @default("Bank payment integration coming soon!") @map("bank_payment_message")

  // ── Payment Method Master Switches ──
  onlinePaymentEnabled Boolean @default(true) @map("online_payment_enabled")
  cashOnArrivalEnabled Boolean @default(true) @map("cash_on_arrival_enabled")

  // ── Booking Widget Master Switches ──
  enableTwoWayTab     Boolean @default(false) @map("enable_two_way_tab")
  enableCityToCityTab Boolean @default(false) @map("enable_city_to_city_tab")
  enableMapSelector   Boolean @default(false) @map("enable_map_selector")
  // Conversational "AI Mode" booking tab (free-text → structured search).
  enableAiMode        Boolean @default(false) @map("enable_ai_mode")
  // CSV of tab keys controlling order/visibility, e.g. "TWO_WAY,ARR,DEP,CITY".
  bookingTabsOrder    String  @default("ARR,DEP") @map("booking_tabs_order")

  // ── SEO ──
  metaTitle       String? @map("meta_title")
  metaDescription String? @map("meta_description")

  // ── Menu Links ──
  navLinksJson Json? @map("nav_links_json")

  // ── Audit ──
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("website_settings")
}

// ─────────────────────────────────────────────
// GOOGLE DRIVE INTEGRATION SETTINGS
// ─────────────────────────────────────────────

model GoogleDriveSettings {
  id String @id @default(uuid())

  enabled           Boolean @default(false)
  oauthClientId     String? @map("oauth_client_id")
  oauthClientSecret String? @map("oauth_client_secret")
  oauthRefreshToken String? @map("oauth_refresh_token") @db.Text
  rootFolderId      String? @map("root_folder_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("google_drive_settings")
}

// ─────────────────────────────────────────────
// B2C WEBSITE CONTENT (CMS)
// City landing pages, blog, and per-page SEO for the public site.
// ─────────────────────────────────────────────

/// Rich-CMS landing page for a City (1:1 with the location-tree City record).
model CityPage {
  id          String  @id @default(uuid())
  cityId      String  @unique @map("city_id")
  slug        String  @unique
  isPublished Boolean @default(false) @map("is_published")
  showInMenu  Boolean @default(true) @map("show_in_menu")
  menuOrder   Int     @default(0) @map("menu_order")

  // ── Content ──
  heroHeadline String? @map("hero_headline")
  heroImageUrl String? @map("hero_image_url")
  introText    String? @map("intro_text") @db.Text
  contentHtml  String? @map("content_html") @db.Text // rich HTML body (WordPress-style)
  bodyJson     Json?   @map("body_json") // [{ heading, body }]
  faqJson      Json?   @map("faq_json") // [{ question, answer }]

  // ── SEO ──
  metaTitle       String? @map("meta_title")
  metaDescription String? @map("meta_description")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  city         City                  @relation(fields: [cityId], references: [id], onDelete: Cascade)
  translations CityPageTranslation[]

  @@index([isPublished, showInMenu])
  @@map("city_pages")
}

model BlogCategory {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  posts BlogPost[] @relation("BlogPostCategories")

  @@map("blog_categories")
}

model BlogPost {
  id            String    @id @default(uuid())
  slug          String    @unique
  title         String
  excerpt       String?   @db.Text
  coverImageUrl String?   @map("cover_image_url")
  contentJson   Json?     @map("content_json") // tiptap document JSON (for re-editing)
  contentHtml   String?   @map("content_html") @db.Text // rendered HTML (for B2C display)
  author        String?
  status        String    @default("DRAFT") // DRAFT | PUBLISHED
  publishedAt   DateTime? @map("published_at")
  tags          String[]  @default([])

  // ── SEO ──
  metaTitle       String? @map("meta_title")
  metaDescription String? @map("meta_description")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  categories   BlogCategory[]        @relation("BlogPostCategories")
  translations BlogPostTranslation[]

  @@index([status, publishedAt])
  @@map("blog_posts")
}

/// Per-page meta title/description for static B2C pages, keyed by a stable pageKey.
model PageSeo {
  id              String   @id @default(uuid())
  pageKey         String   @unique @map("page_key") // home | book | booking-lookup | blog | destinations | ...
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  translations PageSeoTranslation[]

  @@map("page_seo")
}

/// CMS-managed static content pages for the B2C site (Terms, Privacy, About …).
/// WordPress-style: admins create pages, place them in the nav and/or footer
/// menus, and set per-page SEO. The B2C site fetches a published page by slug
/// via GET /public/pages/:slug and the menus via GET /public/pages.
model StaticPage {
  id          String  @id @default(uuid())
  slug        String  @unique // terms-and-conditions | privacy-policy | about-us | …
  title       String
  content     String  @default("") @db.Text // rendered HTML for B2C display
  isPublished Boolean @default(false) @map("is_published")

  // ── Menu placement ──
  showInNav    Boolean @default(false) @map("show_in_nav")
  showInFooter Boolean @default(false) @map("show_in_footer")
  menuOrder    Int     @default(0) @map("menu_order")

  // ── SEO ──
  metaTitle       String? @map("meta_title")
  metaDescription String? @map("meta_description") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  translations StaticPageTranslation[]

  @@map("static_pages")
}

// ─────────────────────────────────────────────
// B2C CONTENT TRANSLATIONS (i18n)
// ─────────────────────────────────────────────

/// Non-English locales supported by the B2C site. English is the base content
/// stored on the parent rows; translations only ever exist for these locales.
enum Locale {
  ar
  de
  fr
  it
  nl
  ru
}

/// Per-locale translation of a destination landing page. Any null field falls
/// back to the English base on the parent CityPage.
model CityPageTranslation {
  id              String   @id @default(uuid())
  cityPageId      String   @map("city_page_id")
  locale          Locale
  heroHeadline    String?  @map("hero_headline")
  introText       String?  @map("intro_text") @db.Text
  contentHtml     String?  @map("content_html") @db.Text
  faqJson         Json?    @map("faq_json")
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  cityPage CityPage @relation(fields: [cityPageId], references: [id], onDelete: Cascade)

  @@unique([cityPageId, locale])
  @@index([cityPageId, locale])
  @@map("city_page_translations")
}

/// Per-locale translation of a blog post. Any null field falls back to English.
model BlogPostTranslation {
  id              String   @id @default(uuid())
  blogPostId      String   @map("blog_post_id")
  locale          Locale
  title           String?
  excerpt         String?  @db.Text
  contentHtml     String?  @map("content_html") @db.Text
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  blogPost BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@unique([blogPostId, locale])
  @@index([blogPostId, locale])
  @@map("blog_post_translations")
}

/// Per-locale translation of a static page's SEO meta. Falls back to English.
model PageSeoTranslation {
  id              String   @id @default(uuid())
  pageSeoId       String   @map("page_seo_id")
  locale          Locale
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  pageSeo PageSeo @relation(fields: [pageSeoId], references: [id], onDelete: Cascade)

  @@unique([pageSeoId, locale])
  @@index([pageSeoId, locale])
  @@map("page_seo_translations")
}

/// Per-locale translation of a CMS static page. Any null field falls back to
/// the English base on the parent StaticPage.
model StaticPageTranslation {
  id              String   @id @default(uuid())
  staticPageId    String   @map("static_page_id")
  locale          Locale
  title           String?
  content         String?  @map("content") @db.Text
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  staticPage StaticPage @relation(fields: [staticPageId], references: [id], onDelete: Cascade)

  @@unique([staticPageId, locale])
  @@index([staticPageId, locale])
  @@map("static_page_translations")
}

/// Inbound contact-form submissions from the B2C site. Stored for the team to
/// review in admin; also emailed to the configured contact address on receipt.
model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String   @db.Text
  ipAddress String?  @map("ip_address")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([isRead, createdAt])
  @@map("contact_messages")
}
