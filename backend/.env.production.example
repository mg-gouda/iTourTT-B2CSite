# B2C standalone backend — production env template.
# Copy to `.env.production` on the VPS and fill real values. `.env.production` is gitignored.
# NOTE: DATABASE_URL + PORT are overridden by docker-compose.yml — leave as-is here.

# ── Core (required) ──
DATABASE_URL=postgres://b2c:CHANGE_ME@postgres:5432/b2c_db   # compose overrides this
PORT=3002                                                     # compose overrides this
TZ=Africa/Cairo
JWT_SECRET=CHANGE_ME_strong_random
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_strong_random_distinct
JWT_REFRESH_EXPIRES_IN=7d

# Public origin(s) allowed by CORS (comma-separated). MUST include the live site.
CORS_ORIGINS=https://transferra.ae,https://www.transferra.ae

# ── Partner seam → iTourTT (required for pricing/jobs push) ──
ITOURTT_API_URL=https://fulvago.itourtt.cloud
PARTNER_API_KEY=CHANGE_ME_must_equal_iTourTT_prod_PARTNER_API_KEY

# ── AI visibility / parser (optional — features degrade gracefully if unset) ──
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar
SERPAPI_KEY=

# ── Email (optional — contact form / notifications) ──
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
CONTACT_EMAIL=

# ── Misc (optional) ──
APP_HOST=https://transferra.ae
TURNSTILE_SECRET=
LICENSE_PUBLIC_KEY=
LICENSE_SERVER_URL=
FIREBASE_SERVICE_ACCOUNT=

# ── Seed toggles (set true to skip re-seeding perms/params on a populated DB) ──
SKIP_PERMISSION_SEED=false
SKIP_SYSTEM_PARAMS_SEED=false
