# Backend API base (the existing dashboard backend). No trailing slash.
# The app calls ${NEXT_PUBLIC_API_URL}/api/public/* and /api/w-api/*.
# Must be available at BUILD time (baked into client bundle) and RUNTIME (SSR).
NEXT_PUBLIC_API_URL=https://fulvago.itourtt.cloud

# Optional — only if the location selectors use Google Maps.
# NEXT_PUBLIC_GOOGLE_MAPS_KEY=
